<%- include('partials/header') %>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .chat-container { background: white; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); overflow: hidden; margin-top: 20px; }
        .chat-window { height: 400px; overflow-y: auto; padding: 20px; background: var(--light-grey); display: flex; flex-direction: column; gap: 10px; }
        .msg { max-width: 70%; padding: 12px; border-radius: 10px; font-size: 0.95rem; line-height: 1.4; }
        .msg.client { align-self: flex-end; background: var(--primary-red); color: white; border-bottom-right-radius: 2px; }
        .msg.admin, .msg.ai { align-self: flex-start; background: var(--medium-grey); color: var(--dark-black); border-bottom-left-radius: 2px; }
        .msg-info { font-size: 0.7rem; margin-bottom: 4px; opacity: 0.8; }
        .chat-input-area { padding: 20px; border-top: 1px solid var(--medium-grey); display: flex; gap: 10px; }
        .chat-input-area input { flex: 1; padding: 12px; border: 1px solid var(--medium-grey); outline: none; }
    </style>
</head>
<body>
    <div class="container" style="margin-top: 120px;">
        <a href="/dashboard" style="text-decoration: none; color: var(--primary-red);">← К списку заявок</a>
        
        <div style="margin-top: 20px;">
            <h2>Заявка #<%= ticket.id %>: <%= ticket.subject %></h2>
            <p>Статус: <strong><%= ticket.status %></strong></p>
        </div>

        <div class="chat-container">
            <div class="chat-window">
                <div class="msg admin">
                    <div class="msg-info">Описание проблемы</div>
                    <%= ticket.description %>
                </div>

                <% messages.forEach(msg => { %>
                    <div class="msg <%= msg.sender_role %>">
                        <div class="msg-info"><%= msg.sender_role === 'client' ? 'Вы' : 'Техподдержка' %> | <%= new Date(msg.created_at).toLocaleTimeString() %></div>
                        <%= msg.message %>
                    </div>
                <% }) %>
            </div>

            <form action="/messages/send" method="POST" class="chat-input-area">
                <input type="hidden" name="ticket_id" value="<%= ticket.id %>">
                <input type="text" name="message" placeholder="Введите сообщение..." required autocomplete="off">
                <button type="submit" class="btn btn-red" style="margin: 0;">Отправить</button>
            </form>
        </div>
    </div>
    <%- include('partials/footer') %>