<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Оренспецстрой | Сервисный портал</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
</head>
<body>
    <header id="main-header">
        <div class="container header-flex">
            <div class="logo">
                <a href="/">
                    <span class="logo-bold">ОРЕН</span>СПЕЦСТРОЙ
                </a>
            </div>
            <nav>
                <ul>
                    <% if (user && user.role === 'admin') { %>
                        <li>
                            <a href="/admin" class="<%= activePage.startsWith('/admin') ? 'active' : '' %>">Панель управления</a>
                        </li>
                    <% } %>
                    
                    <li>
                        <a href="/" class="<%= activePage === '/' ? 'active' : '' %>">Главная</a>
                    </li>
                    <li>
                        <a href="/services" class="<%= activePage === '/services' ? 'active' : '' %>">Услуги</a>
                    </li>
                    <li>
                        <a href="/kb" class="<%= activePage.startsWith('/kb') ? 'active' : '' %>">База знаний</a>
                    </li>
                    
                    <% if (user) { %>
                        <li><a href="/dashboard">Личный кабинет</a></li>
                        <% if (user.role === 'admin') { %>
                            <li><a href="/admin" style="color: #EF4A20;"><i class="fas fa-user-shield"></i> Админка</a></li>
                        <% } %>
                        <li>
                            <a href="/logout" style="color: #EF4A20; font-weight: bold;">
                                <i class="fas fa-sign-out-alt"></i> Выйти
                            </a>
                        </li>
                    <% } else { %>
                        <li><a href="/login" class="btn-login-nav">Войти</a></li>
                    <% } %>
                </ul>
            </nav>
        </div>
    </header>