<%- include('../partials/header') %>

<style>
    .admin-container {
        padding-top: 100px;
        padding-bottom: 60px;
        background: #0a0a0a;
        min-height: 100vh;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: #1a1a1a;
        padding: 25px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid #333;
    }
    .stat-card h3 {
        font-size: 2rem;
        margin: 10px 0;
        color: #e31b23;
    }
    .stat-card p {
        color: #ffffff;
    }
    .admin-table {
        width: 100%;
        background: #1a1a1a;
        border-radius: 16px;
        overflow: hidden;
    }
    .admin-table th {
        background: #e31b23;
        padding: 15px;
        text-align: left;
    }
    .admin-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #333;
    }
    .status-select {
        background: #2a2a2a;
        color: white;
        border: 1px solid #555;
        padding: 5px 10px;
        border-radius: 6px;
    }
    .btn-view {
        color: #e31b23;
        text-decoration: none;
    }
    .urgency-emergency { color: #e31b23; font-weight: bold; }
    .urgency-urgent { color: #ffc107; }
</style>

<main class="admin-container">
    <div class="container">
        <h1 style="margin-bottom: 10px;">Админ-панель</h1>
        <p style="color: #888; margin-bottom: 30px;">Управление заявками клиентов</p>
        
        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-ticket-alt"></i>
                <h3><%= stats.total %></h3>
                <p>Всего заявок</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-clock"></i>
                <h3><%= stats.new + stats.processing %></h3>
                <p>Активные</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-check-circle"></i>
                <h3><%= stats.completed %></h3>
                <p>Завершено</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-bell"></i>
                <h3><%= stats.emergency %></h3>
                <p>Аварийные</p>
            </div>
        </div>
        
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Клиент</th><th>Тема</th><th>Срочность</th><th>Статус</th><th>Дата</th><th></th></tr>
            </thead>
            <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                    <td>#<%= ticket.id %></td>
                    <td><%= ticket.user_fio || 'Неизвестно' %></td>
                    <td><%= ticket.subject %></td>
                    <td>
                        <span class="<%= ticket.urgency === 'emergency' ? 'urgency-emergency' : (ticket.urgency === 'urgent' ? 'urgency-urgent' : '') %>">
                            <%= ticket.urgency === 'emergency' ? '🚨 Аварийная' : (ticket.urgency === 'urgent' ? '⚠️ Срочная' : 'Обычная') %>
                        </span>
                    </td>
                    <td>
                        <select class="status-select" onchange="updateStatus(<%= ticket.id %>, this.value)">
                            <option value="Новая" <%= ticket.status === 'Новая' ? 'selected' : '' %>>Новая</option>
                            <option value="В обработке" <%= ticket.status === 'В обработке' ? 'selected' : '' %>>В обработке</option>
                            <option value="Завершено" <%= ticket.status === 'Завершено' ? 'selected' : '' %>>Завершено</option>
                        </select>
                    </td>
                    <td><%= new Date(ticket.created_at).toLocaleDateString() %></td>
                    <td><a href="/admin/tickets/<%= ticket.id %>" class="btn-view">Подробнее</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</main>

<script>
function updateStatus(ticketId, status) {
    fetch('/admin/update-status', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ ticketId, status })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) location.reload();
        else alert('Ошибка');
    });
}
</script>

<%- include('../partials/footer') %>