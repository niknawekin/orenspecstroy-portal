<%- include('../partials/admin/header') %>
<%- include('../partials/admin/sidebar') %>

<style>
    .admin-container {
        padding-top: 100px;
        padding-bottom: 60px;
        background: #0a0a0a;
        min-height: 100vh;
    }
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    .stat-card {
        background: #1a1a1a;
        padding: 25px;
        border-radius: 16px;
        text-align: center;
        border: 1px solid #333;
    }
    .stat-card h3 {
        font-size: 2rem;
        margin: 10px 0;
        color: #e31b23;
    }
    .stat-card p {
        color: #ffffff;
    }
    .admin-table {
        width: 100%;
        background: #1a1a1a;
        border-radius: 16px;
        overflow: hidden;
    }
    .admin-table th {
        background: #e31b23;
        padding: 15px;
        text-align: left;
    }
    .admin-table td {
        padding: 12px 15px;
        border-bottom: 1px solid #333;
    }
    .status-select {
        background: #2a2a2a;
        color: white;
        border: 1px solid #555;
        padding: 5px 10px;
        border-radius: 6px;
    }
    .btn-view {
        color: #e31b23;
        text-decoration: none;
    }
    .urgency-emergency { color: #e31b23; font-weight: bold; }
    .urgency-urgent { color: #ffc107; }
</style>

<main class="admin-container">
    <div class="container">
        <h1 style="margin-bottom: 10px;">Админ-панель</h1>
        <p style="color: #888; margin-bottom: 30px;">Управление заявками клиентов</p>
        
        <div class="stats-grid">
            <div class="stat-card">
                <i class="fas fa-ticket-alt"></i>
                <h3><%= stats.total %></h3>
                <p>Всего заявок</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-clock"></i>
                <h3><%= stats.new + stats.processing %></h3>
                <p>Активные</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-check-circle"></i>
                <h3><%= stats.completed %></h3>
                <p>Завершено</p>
            </div>
            <div class="stat-card">
                <i class="fas fa-bell"></i>
                <h3><%= stats.emergency %></h3>
                <p>Аварийные</p>
            </div>
        </div>
        <div class="filter-container" style="margin-bottom: 20px; display: flex; gap: 10px;">
            <button class="filter-btn active" data-filter="all" style="background: #222; color: #fff; border: 1px solid #333; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Все задачи</button>
            <button class="filter-btn" data-filter="active" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">В работе</button>
            <button class="filter-btn" data-filter="emergency" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">🚨 Аварийные</button>
            <button class="filter-btn" data-filter="completed" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Выполненные</button>
        </div>
        <table class="admin-table">
            <thead>
                <tr><th>ID</th><th>Клиент</th><th>Тема</th><th>Срочность</th><th>Статус</th><th>Дата</th><th>Дата выезда</th><th></th></tr>
            </thead>
            <tbody>
                <% tickets.forEach(ticket => { %>
                <tr>
                    <td>#<%= ticket.id %></td>
                    <td><%= ticket.user_fio || 'Неизвестно' %></td>
                    <td><%= ticket.subject %></td>
                    <td>
                        <span class="<%= ticket.urgency === 'emergency' ? 'urgency-emergency' : (ticket.urgency === 'urgent' ? 'urgency-urgent' : '') %>">
                            <%= ticket.urgency === 'emergency' ? 'Аварийная' : (ticket.urgency === 'urgent' ? 'Срочная' : 'Обычная') %>
                        </span>
                    </td>
                    <td>
                        <select class="status-select" onchange="updateStatus(<%= ticket.id %>, this.value)">
                            <option value="Новая" <%= ticket.status === 'Новая' ? 'selected' : '' %>>Новая</option>
                            <option value="В обработке" <%= ticket.status === 'В обработке' ? 'selected' : '' %>>В обработке</option>
                            <option value="Завершено" <%= ticket.status === 'Завершено' ? 'selected' : '' %>>Завершено</option>
                        </select>
                    </td>
                    <td>
                        <% if (ticket.booking_date) { %>
                            <span class="badge style-date" style="background: rgba(227, 27, 35, 0.1); color: #e31b23; border: 1px solid #e31b23; padding: 5px 10px; border-radius: 4px;">
                                <%= ticket.booking_date.split('-').reverse().join('.') %>
                            </span>
                        <% } else { %>
                            <span class="text-muted" style="font-size: 0.9rem;">Не указана</span>
                        <% } %>
                    </td>
                    <td><%= new Date(ticket.created_at).toLocaleDateString() %></td>
                    <td><a href="/admin/tickets/<%= ticket.id %>" class="btn-view">Подробнее</a></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</main>

<script>
    // Фильтрация заявок
    const filterBtns = document.querySelectorAll('.filter-btn');
    // Находим все строки таблицы в теле (пропуская заголовок th)
    const ticketRows = document.querySelectorAll('.admin-table tbody tr');
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            // Обновляем активный класс у кнопок
            filterBtns.forEach(b => b.classList.remove('active'));
            this.classList.add('active');
            
            const filter = this.getAttribute('data-filter'); // получаем: all, processing, done
            
            ticketRows.forEach(row => {
                // Получаем статус из атрибута строки (приводим к нижнему регистру для надежности)
                // или проверяем текстовое содержимое ячейки статуса
                const statusAttr = row.getAttribute('data-status') ? row.getAttribute('data-status').toLowerCase() : '';
                
                // Если статус зашит в тексте ячейки (например, "В обработке", "Завершено", "Новая")
                const statusText = row.querySelector('.status-select') ? row.querySelector('.status-select').value.toLowerCase() : row.textContent.toLowerCase();

                if (filter === 'all') {
                    // Для строк таблицы вместо 'block' нужно использовать 'table-row' или пустую строку ''
                    row.style.display = ''; 
                } else if (filter === 'processing') {
                    // Проверяем статус (и английский вариант, и русский)
                    if (statusAttr === 'processing' || statusText.includes('обработк') || statusText.includes('нов')) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                } else if (filter === 'done') {
                    if (statusAttr === 'done' || statusText.includes('заверш') || statusText.includes('выполн')) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                }
            });
        });
    });
</script>

<%- include('../partials/admin/footer') %>