<%- include('../partials/admin/header') %>
<%- include('../partials/admin/sidebar') %>
<style>
    .admin-dashboard { padding-top: 100px; background: #ffffff; min-height: 100vh; }
    .stats-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin-bottom: 40px; }
    .stat-card { background: #1a1a1a; padding: 25px; border-radius: 16px; text-align: center; border: 1px solid #333; }
    .stat-card h2 { font-size: 2.5rem; color: #e31b23; margin: 10px 0; }
    .stat-card p { color: #ffffff; }
    .nav-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-top: 40px; }
    .nav-card { background: #1a1a1a; padding: 30px; border-radius: 16px; text-align: center; text-decoration: none; color: white; transition: 0.3s; border: 1px solid #333; }
    .nav-card:hover { transform: translateY(-5px); border-color: #e31b23; }
    .nav-card i { font-size: 2.5rem; color: #e31b23; margin-bottom: 15px; }
</style>
<main class="admin-dashboard">
    <div class="container">
        <h1>Панель управления</h1>
        <p style="color: #888; margin-bottom: 30px;">Добро пожаловать, <%= user.fio %></p>
        
        <div class="stats-grid">
            <div class="stat-card"><i class="fas fa-ticket-alt"></i><h2><%= stats.totalTickets %></h2><p>Всего заявок</p></div>
            <div class="stat-card"><i class="fas fa-clock"></i><h2><%= stats.newTickets + stats.processingTickets %></h2><p>Активные</p></div>
            <div class="stat-card"><i class="fas fa-check-circle"></i><h2><%= stats.completedTickets %></h2><p>Завершено</p></div>
            <div class="stat-card"><i class="fas fa-bell"></i><h2><%= stats.emergencyTickets %></h2><p>Аварийные</p></div>
            <div class="stat-card"><i class="fas fa-users"></i><h2><%= stats.totalUsers %></h2><p>Пользователей</p></div>
            <div class="stat-card"><i class="fas fa-calendar-day"></i><h2><%= stats.todayTickets %></h2><p>За сегодня</p></div>
        </div>
        
        <div class="nav-grid">
            <a href="/admin/users" class="nav-card"><i class="fas fa-users"></i><h3>Пользователи</h3><p>Управление клиентами</p></a>
            <a href="/admin/tickets" class="nav-card"><i class="fas fa-ticket-alt"></i><h3>Заявки</h3><p>Все обращения</p></a>
            <a href="/admin/specialists" class="nav-card"><i class="fas fa-user-cog"></i><h3>Специалисты</h3><p>Мастера и инженеры</p></a>
            <a href="/admin/kb" class="nav-card"><i class="fas fa-book"></i><h3>База знаний</h3><p>Статьи и инструкции</p></a>
            <a href="/admin/prices" class="nav-card"><i class="fas fa-ruble-sign"></i><h3>Прайс-лист</h3><p>Управление ценами</p></a>
            <a href="/admin/reports" class="nav-card"><i class="fas fa-chart-line"></i><h3>Отчёты</h3><p>Статистика и аналитика</p></a>
        </div>
    </div>
</main>
<%- include('../partials/admin/footer') %>