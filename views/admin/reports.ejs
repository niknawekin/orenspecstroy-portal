<%- include('../partials/header') %>

<style>
    .reports-page {
        padding-top: 100px;
        padding-bottom: 60px;
        background: #0a0a0a;
        min-height: 100vh;
    }
    
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }
    
    .page-header {
        margin-bottom: 30px;
    }
    
    .page-header h1 {
        font-size: 2rem;
        color: white;
    }
    
    .page-header h1 i {
        color: #e31b23;
        margin-right: 10px;
    }
    
    .kpi-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    
    .kpi-card {
        background: #1a1a1a;
        border-radius: 16px;
        padding: 25px;
        border: 1px solid #333;
    }
    
    .kpi-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: #e31b23;
    }
    
    .kpi-label {
        color: #888;
        margin-top: 5px;
    }
    
    .report-section {
        background: #1a1a1a;
        border-radius: 16px;
        padding: 25px;
        margin-bottom: 30px;
        border: 1px solid #333;
    }
    
    .section-title {
        font-size: 1.2rem;
        font-weight: 700;
        margin-bottom: 20px;
        color: white;
    }
    
    .section-title i {
        color: #e31b23;
        margin-right: 10px;
    }
    
    .chart-bars {
        display: flex;
        align-items: flex-end;
        justify-content: space-around;
        height: 250px;
        gap: 10px;
    }
    
    .bar-item {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    
    .bar {
        width: 100%;
        background: linear-gradient(180deg, #e31b23, #b3050f);
        border-radius: 8px;
        min-height: 4px;
    }
    
    .bar-label {
        font-size: 0.7rem;
        color: #888;
    }
    
    .equipment-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .equipment-table th,
    .equipment-table td {
        padding: 12px;
        text-align: left;
        border-bottom: 1px solid #333;
        color: white;
    }
    
    .equipment-table th {
        color: #888;
    }
    
    .progress-bar {
        width: 150px;
        height: 6px;
        background: #333;
        border-radius: 3px;
        overflow: hidden;
    }
    
    .progress-fill {
        height: 100%;
        background: #e31b23;
        border-radius: 3px;
    }
    
    .stats-list {
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    
    .stat-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #333;
        color: white;
    }
    
    .stat-name {
        color: #888;
    }
    
    .btn-export {
        background: #333;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        color: white;
        cursor: pointer;
        margin-right: 10px;
    }
    
    .btn-export:hover {
        background: #e31b23;
    }
    
    @media (max-width: 768px) {
        .chart-bars {
            height: auto;
            flex-direction: column;
        }
        .bar-item {
            flex-direction: row;
            justify-content: space-between;
        }
        .bar {
            width: 60%;
            height: 30px !important;
        }
        .equipment-table {
            display: block;
            overflow-x: auto;
        }
    }
</style>

<main class="reports-page">
    <div class="container">
        <div class="page-header">
            <h1><i class="fas fa-chart-line"></i> Статистика и отчёты</h1>
            <button class="btn-export" onclick="exportToCSV()">
                <i class="fas fa-file-csv"></i> Экспорт CSV
            </button>
        </div>
        
        <!-- KPI Карточки -->
        <div class="kpi-grid">
            <div class="kpi-card">
                <div class="kpi-value"><%= stats.totalTickets || 0 %></div>
                <div class="kpi-label">Всего заявок</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value"><%= stats.processingTickets || 0 %></div>
                <div class="kpi-label">В обработке</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value"><%= stats.completedTickets || 0 %></div>
                <div class="kpi-label">Завершено</div>
            </div>
            <div class="kpi-card">
                <div class="kpi-value"><%= stats.totalUsers || 0 %></div>
                <div class="kpi-label">Всего клиентов</div>
            </div>
        </div>
        
        <!-- Динамика заявок -->
        <div class="report-section">
            <div class="section-title">
                <i class="fas fa-chart-bar"></i> Динамика обращений (последние 7 дней)
            </div>
            <div class="chart-bars">
                <% if (dailyStats && dailyStats.length > 0) { 
                    const maxCount = Math.max(...dailyStats.map(d => d.count), 1);
                    dailyStats.forEach(day => { 
                        const height = (day.count / maxCount) * 200;
                %>
                    <div class="bar-item">
                        <div class="bar" style="height: <%= Math.max(height, 10) %>px;"></div>
                        <div class="bar-value"><%= day.count %></div>
                        <div class="bar-label"><%= day.date %></div>
                    </div>
                <% }) } else { %>
                    <div style="text-align: center; color: #888;">Нет данных</div>
                <% } %>
            </div>
        </div>
        
        <!-- Статистика по оборудованию -->
        <div class="report-section">
            <div class="section-title">
                <i class="fas fa-microchip"></i> Типы оборудования
            </div>
            <table class="equipment-table">
                <thead>
                    <tr><th>Тип</th><th>Количество</th><th></th></tr>
                </thead>
                <tbody>
                    <% if (equipmentStats && equipmentStats.length > 0) { 
                        const total = equipmentStats.reduce((s, e) => s + e.count, 0);
                        equipmentStats.forEach(equip => { 
                            const percent = total > 0 ? (equip.count / total * 100).toFixed(1) : 0;
                    %>
                        <tr>
                            <td><%= equip.equipment_type %></td>
                            <td><%= equip.count %></td>
                            <td><div class="progress-bar"><div class="progress-fill" style="width: <%= percent %>%;"></div></div></td>
                        </tr>
                    <% }) } else { %>
                        <tr><td colspan="3" style="text-align: center;">Нет данных</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Общая статистика -->
        <div class="report-section">
            <div class="section-title">
                <i class="fas fa-chart-pie"></i> Общая статистика
            </div>
            <div class="stats-list">
                <div class="stat-row">
                    <span class="stat-name">Аварийные заявки</span>
                    <span><%= stats.emergencyTickets || 0 %></span>
                </div>
                <div class="stat-row">
                    <span class="stat-name">Срочные заявки</span>
                    <span><%= stats.urgentTickets || 0 %></span>
                </div>
                <div class="stat-row">
                    <span class="stat-name">Обычные заявки</span>
                    <span><%= stats.normalTickets || 0 %></span>
                </div>
                <div class="stat-row">
                    <span class="stat-name">Среднее время выполнения</span>
                    <span><%= avgCompletionTime && avgCompletionTime.avg_days ? avgCompletionTime.avg_days.toFixed(1) : '—' %> дней</span>
                </div>
                <div class="stat-row">
                    <span class="stat-name">Процент завершённых</span>
                    <span><%= stats.totalTickets > 0 ? ((stats.completedTickets / stats.totalTickets) * 100).toFixed(1) : 0 %>%</span>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    function exportToCSV() {
        let csv = "Статистика заявок\n\n";
        csv += `Всего заявок,${<%= stats.totalTickets || 0 %>}\n`;
        csv += `В обработке,${<%= stats.processingTickets || 0 %>}\n`;
        csv += `Завершено,${<%= stats.completedTickets || 0 %>}\n`;
        csv += `Всего клиентов,${<%= stats.totalUsers || 0 %>}\n`;
        
        const blob = new Blob([csv], { type: 'text/csv' });
        const link = document.createElement('a');
        link.href = URL.createObjectURL(blob);
        link.download = `report_${new Date().toISOString().split('T')[0]}.csv`;
        link.click();
        URL.revokeObjectURL(link.href);
    }
</script>

<%- include('../partials/footer') %>