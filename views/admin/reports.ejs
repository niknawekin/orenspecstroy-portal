<%- include('../partials/admin/header') %>
<%- include('../partials/admin/sidebar') %>

<main class="admin-main-content" style="padding: 40px;">
    <h1>Аналитика и отчеты</h1>
    
    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top: 30px;">
        <div style="background: #111; padding: 20px; border-radius: 16px;">
            <h3>Распределение заявок</h3>
            <canvas id="ticketsChart"></canvas>
        </div>

        <div style="background: #111; padding: 20px; border-radius: 16px;">
            <h3>Загрузка специалистов</h3>
            <canvas id="loadChart"></canvas>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    // Безопасное получение данных из сервера
    const statusStats = <%- JSON.stringify(typeof statusStats !== 'undefined' ? statusStats : []) %>;
    const specialistStats = <%- JSON.stringify(typeof specialistStats !== 'undefined' ? specialistStats : []) %>;

    // График статусов
    const ctx1 = document.getElementById('ticketsChart').getContext('2d');
    new Chart(ctx1, {
        type: 'doughnut',
        data: {
            labels: statusStats.map(s => s.status),
            datasets: [{
                data: statusStats.map(s => s.count),
                backgroundColor: ['#e31b23', '#ffc107', '#28a745', '#17a2b8']
            }]
        }
    });

    // График нагрузки
    const ctx2 = document.getElementById('loadChart').getContext('2d');
    new Chart(ctx2, {
        type: 'bar',
        data: {
            labels: specialistStats.map(s => s.fio),
            datasets: [{
                label: 'Активных заявок',
                data: specialistStats.map(s => s.task_count),
                backgroundColor: '#e31b23'
            }]
        }
    });
</script>