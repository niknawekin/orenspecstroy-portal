<%- include('../partials/admin/header') %>
<%- include('../partials/admin/sidebar') %>

<style>
    /* Основные стили */
    .admin-users {
        padding-top: 100px;
        padding-bottom: 60px;
        background: linear-gradient(135deg, #0a0a0a 0%, #0f0f0f 100%);
        min-height: 100vh;
    }
    
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 30px;
    }
    
    /* Заголовок страницы */
    .page-header {
        display: flex;
    justify-content: space-between;
    align-items: center;
        margin-bottom: 40px;
        flex-wrap: wrap;
        gap: 20px;
    }
    
    .page-header h1 {
        font-size: 2rem;
        font-weight: 800;
        background: linear-gradient(135deg, #fff 0%, #e31b23 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        margin: 0;
    }
    
    .page-header h1 i {
        background: none;
        -webkit-text-fill-color: #e31b23;
        margin-right: 10px;
    }
    
    .header-actions {
        display: flex;
        gap: 15px;
        align-items: center;
    }
    
    /* Кнопки */
    .btn-back {
        background: rgba(255, 255, 255, 0.1);
        color: white;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }
    
    .btn-back:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateX(-3px);
    }
    
    .btn-add {
        background: linear-gradient(135deg, #28a745 0%, #1e7e34 100%);
        color: white;
        padding: 10px 24px;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-weight: 600;
        border: none;
        cursor: pointer;
    }
    
    .btn-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(40, 167, 69, 0.3);
    }
    
    /* Статистика */
    .stats-row {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    
    .stat-mini-card {
        background: rgba(26, 26, 26, 0.8);
        backdrop-filter: blur(10px);
        border-radius: 16px;
        padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }
    
    .stat-mini-card:hover {
        border-color: #e31b23;
        transform: translateY(-3px);
    }
    
    .stat-mini-card .stat-icon {
        font-size: 2rem;
        margin-bottom: 10px;
    }
    
    .stat-mini-card .stat-number {
        font-size: 2rem;
        font-weight: 800;
        color: white;
    }
    
    .stat-mini-card .stat-label {
        color: #888;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    /* Поиск и фильтры */
    .search-section {
        background: rgba(26, 26, 26, 0.6);
        border-radius: 16px;
        padding: 20px;
        margin-bottom: 30px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .search-box {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }
    
    .search-input-wrapper {
        flex: 1;
        position: relative;
    }
    
    .search-input-wrapper i {
        position: absolute;
        left: 15px;
        top: 50%;
        transform: translateY(-50%);
        color: #888;
    }
    
    .search-input-wrapper input {
        width: 100%;
        padding: 12px 15px 12px 45px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 12px;
        color: white;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }
    
    .search-input-wrapper input:focus {
        outline: none;
        border-color: #e31b23;
        box-shadow: 0 0 10px rgba(227, 27, 35, 0.2);
    }
    
    .filter-buttons {
        display: flex;
        gap: 10px;
    }
    
    .filter-btn {
        padding: 8px 20px;
        background: #1a1a1a;
        border: 1px solid #333;
        border-radius: 10px;
        color: #888;
        cursor: pointer;
        transition: all 0.3s ease;
    }
    
    .filter-btn.active {
        background: #e31b23;
        border-color: #e31b23;
        color: white;
    }
    
    .filter-btn:hover {
        border-color: #e31b23;
        color: white;
    }
    
    /* Таблица пользователей */
    .users-table-container {
        background: rgba(26, 26, 26, 0.6);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }
    
    .users-table {
        width: 100%;
        border-collapse: collapse;
    }
    
    .users-table thead {
        background: linear-gradient(135deg, #1a1a1a 0%, #0f0f0f 100%);
        border-bottom: 1px solid #333;
    }
    
    .users-table th {
        padding: 18px 20px;
        text-align: left;
        color: #888;
        font-weight: 600;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 1px;
    }
    
    .users-table td {
        padding: 16px 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        color: white;
        vertical-align: middle;
    }
    
    .users-table tbody tr {
        transition: all 0.3s ease;
    }
    
    .users-table tbody tr:hover {
        background: rgba(227, 27, 35, 0.05);
    }
    
    /* Аватар пользователя */
    .user-avatar {
        width: 40px;
        height: 40px;
        background: linear-gradient(135deg, #e31b23, #b3050f);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 700;
        font-size: 1rem;
    }
    
    .user-info {
        display: flex;
        align-items: center;
        gap: 12px;
    }
    
    .user-details {
        display: flex;
        flex-direction: column;
    }
    
    .user-name {
        font-weight: 600;
        margin-bottom: 4px;
    }
    
    .user-email {
        font-size: 0.75rem;
        color: #888;
    }
    
    /* Бейджи ролей */
    .role-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    
    .role-admin {
        background: linear-gradient(135deg, #e31b23, #b3050f);
        color: white;
        box-shadow: 0 2px 8px rgba(227, 27, 35, 0.3);
    }
    
    .role-specialist {
        background: linear-gradient(135deg, #ffc107, #ff9800);
        color: #000;
    }
    
    .role-user {
        background: rgba(40, 167, 69, 0.2);
        color: #28a745;
        border: 1px solid #28a745;
    }
    
    /* Бейдж статуса */
    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 600;
    }
    
    .status-active {
        background: rgba(40, 167, 69, 0.15);
        color: #28a745;
        border: 1px solid #28a745;
    }
    
    .status-inactive {
        background: rgba(108, 117, 125, 0.15);
        color: #6c757d;
        border: 1px solid #6c757d;
    }
    
    .status-blocked {
        background: rgba(227, 27, 35, 0.15);
        color: #e31b23;
        border: 1px solid #e31b23;
    }
    
    /* Кнопки действий */
    .action-buttons {
        display: flex;
        gap: 10px;
    }
    
    .btn-icon {
        width: 34px;
        height: 34px;
        border-radius: 8px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transition: all 0.3s ease;
        cursor: pointer;
        border: none;
    }
    
    .btn-edit {
        background: rgba(255, 193, 7, 0.15);
        color: #ffc107;
    }
    
    .btn-edit:hover {
        background: #ffc107;
        color: #000;
        transform: scale(1.05);
    }
    
    .btn-delete {
        background: rgba(227, 27, 35, 0.15);
        color: #e31b23;
    }
    
    .btn-delete:hover {
        background: #e31b23;
        color: white;
        transform: scale(1.05);
    }
    
    .btn-view {
        background: rgba(23, 162, 184, 0.15);
        color: #17a2b8;
    }
    
    .btn-view:hover {
        background: #17a2b8;
        color: white;
        transform: scale(1.05);
    }
    
    /* Пустое состояние */
    .empty-state {
        text-align: center;
        padding: 60px 20px;
    }
    
    .empty-state i {
        font-size: 4rem;
        color: #333;
        margin-bottom: 20px;
    }
    
    .empty-state p {
        color: #888;
        margin-bottom: 20px;
    }
    
    /* Пагинация */
    .pagination {
        display: flex;
        justify-content: center;
        gap: 10px;
        margin-top: 30px;
        padding: 20px;
    }
    
    .page-link {
        width: 40px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #1a1a1a;
        border-radius: 10px;
        text-decoration: none;
        color: white;
        transition: all 0.3s ease;
    }
    
    .page-link.active {
        background: #e31b23;
    }
    
    .page-link:hover {
        background: #e31b23;
        transform: translateY(-2px);
    }
    
    /* Адаптив */
    @media (max-width: 992px) {
        .users-table {
            display: block;
            overflow-x: auto;
        }
        
        .stats-row {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    
    @media (max-width: 768px) {
        .container {
            padding: 0 20px;
        }
        
        .page-header {
            flex-direction: column;
            align-items: flex-start;
        }
        
        .search-box {
            flex-direction: column;
        }
        
        .stats-row {
            grid-template-columns: 1fr;
        }
    }
    
    /* Модальное окно */
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(5px);
        z-index: 10000;
        align-items: center;
        justify-content: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background: #1a1a1a;
        border-radius: 20px;
        padding: 30px;
        max-width: 500px;
        width: 90%;
        border: 1px solid #e31b23;
    }
    
    .modal-content h3 {
        margin-bottom: 20px;
    }
    
    .modal-buttons {
        display: flex;
        gap: 15px;
        justify-content: flex-end;
        margin-top: 25px;
    }
</style>

<main class="admin-users">
    <div class="container">
        <!-- Заголовок -->
        <div class="page-header">
            <h1>
                <i class="fas fa-users"></i> 
                Управление пользователями
            </h1>
            <div class="header-actions">
                <a href="/admin" class="btn-back">
                    <i class="fas fa-arrow-left"></i> Назад
                </a>
                <button onclick="openAddModal()" class="btn-add">
                    <i class="fas fa-plus"></i> Добавить пользователя
                </button>
            </div>
        </div>
        
        <!-- Статистика -->
        <div class="stats-row">
            <div class="stat-mini-card">
                <div class="stat-icon"><i class="fas fa-users" style="color: #e31b23;"></i></div>
                <div class="stat-number"><%= users.length %></div>
                <div class="stat-label">Всего пользователей</div>
            </div>
            <div class="stat-mini-card">
                <div class="stat-icon"><i class="fas fa-crown" style="color: #ffc107;"></i></div>
                <div class="stat-number"><%= users.filter(u => u.role === 'admin').length %></div>
                <div class="stat-label">Администраторов</div>
            </div>
            <div class="stat-mini-card">
                <div class="stat-icon"><i class="fas fa-user-cog" style="color: #17a2b8;"></i></div>
                <div class="stat-number"><%= users.filter(u => u.role === 'specialist').length %></div>
                <div class="stat-label">Специалистов</div>
            </div>
            <div class="stat-mini-card">
                <div class="stat-icon"><i class="fas fa-user" style="color: #28a745;"></i></div>
                <div class="stat-number"><%= users.filter(u => u.role === 'user').length %></div>
                <div class="stat-label">Клиентов</div>
            </div>
        </div>
        
        <!-- Поиск и фильтры -->
        <div class="search-section">
            <div class="search-box">
                <div class="search-input-wrapper">
                    <i class="fas fa-search"></i>
                    <input type="text" id="searchInput" placeholder="Поиск по имени, email или телефону...">
                </div>
                <div class="filter-buttons">
                    <button class="filter-btn active" data-filter="all">Все</button>
                    <button class="filter-btn" data-filter="admin">Админы</button>
                    <button class="filter-btn" data-filter="specialist">Специалисты</button>
                    <button class="filter-btn" data-filter="user">Клиенты</button>
                </div>
            </div>
        </div>
        
        <!-- Таблица пользователей -->
        <div class="users-table-container">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Пользователь</th>
                        <th>Контакты</th>
                        <th>Роль</th>
                        <th>Заявок</th>
                        <th>Регистрация</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody id="usersTableBody">
                    <% users.forEach(user => { %>
                        <tr data-role="<%= user.role %>" data-name="<%= user.fio.toLowerCase() %>" data-email="<%= user.email.toLowerCase() %>">
                            <td>
                                <div class="user-info">
                                    <div class="user-avatar">
                                        <%= user.fio.charAt(0).toUpperCase() %>
                                    </div>
                                    <div class="user-details">
                                        <span class="user-name"><%= user.fio %></span>
                                        <span class="user-email"><%= user.email %></span>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <i class="fas fa-phone" style="color: #888; margin-right: 8px;"></i>
                                <%= user.phone || 'Не указан' %>
                            </td>
                            <td>
                                <span class="role-badge role-<%= user.role %>">
                                    <i class="fas <%= user.role === 'admin' ? 'fa-crown' : (user.role === 'specialist' ? 'fa-wrench' : 'fa-user') %>"></i>
                                    <%= user.role === 'admin' ? 'Администратор' : (user.role === 'specialist' ? 'Специалист' : 'Клиент') %>
                                </span>
                            </td>
                            <td>
                                <span class="status-badge status-active">
                                    <i class="fas fa-ticket-alt"></i> <%= user.tickets_count || 0 %> заявок
                                </span>
                            </td>
                            <td style="color: #888; font-size: 0.85rem;">
                                <i class="far fa-calendar-alt"></i> <%= new Date(user.created_at).toLocaleDateString('ru-RU') %>
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <a href="/admin/users/<%= user.id %>/edit" class="btn-icon btn-edit" title="Редактировать">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button onclick="deleteUser(<%= user.id %>)" class="btn-icon btn-delete" title="Удалить">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                    <a href="/admin/tickets?user_id=<%= user.id %>" class="btn-icon btn-view" title="Заявки">
                                        <i class="fas fa-eye"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
            
            <% if (users.length === 0) { %>
                <div class="empty-state">
                    <i class="fas fa-users-slash"></i>
                    <p>Пользователи не найдены</p>
                </div>
            <% } %>
        </div>
        
        <!-- Пагинация -->
        <div class="pagination" id="pagination"></div>
    </div>
</main>

<!-- Модальное окно добавления пользователя -->
<div class="modal" id="addUserModal">
    <div class="modal-content">
        <h3><i class="fas fa-user-plus"></i> Добавить пользователя</h3>
        <form action="/admin/users/add" method="POST">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">ФИО</label>
                <input type="text" name="fio" required style="width: 100%; padding: 10px; background: #2a2a2a; border: 1px solid #444; border-radius: 8px; color: white;">
            </div>
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Email</label>
                <input type="email" name="email" required style="width: 100%; padding: 10px; background: #2a2a2a; border: 1px solid #444; border-radius: 8px; color: white;">
            </div>
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Телефон</label>
                <input type="tel" name="phone" style="width: 100%; padding: 10px; background: #2a2a2a; border: 1px solid #444; border-radius: 8px; color: white;">
            </div>
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Роль</label>
                <select name="role" style="width: 100%; padding: 10px; background: #2a2a2a; border: 1px solid #444; border-radius: 8px; color: white;">
                    <option value="user">Клиент</option>
                    <option value="specialist">Специалист</option>
                    <option value="admin">Администратор</option>
                </select>
            </div>
            <div class="modal-buttons">
                <button type="button" onclick="closeModal()" class="btn-back">Отмена</button>
                <button type="submit" class="btn-add">Добавить</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Поиск и фильтрация
    const searchInput = document.getElementById('searchInput');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const tableRows = document.querySelectorAll('#usersTableBody tr');
    
    let currentFilter = 'all';
    let currentSearch = '';
    
    function filterUsers() {
        tableRows.forEach(row => {
            const role = row.getAttribute('data-role');
            const name = row.getAttribute('data-name');
            const email = row.getAttribute('data-email');
            
            const matchesFilter = currentFilter === 'all' || role === currentFilter;
            const matchesSearch = currentSearch === '' || 
                name.includes(currentSearch) || 
                email.includes(currentSearch);
            
            if (matchesFilter && matchesSearch) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    }
    
    searchInput.addEventListener('input', (e) => {
        currentSearch = e.target.value.toLowerCase();
        filterUsers();
    });
    
    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            currentFilter = btn.getAttribute('data-filter');
            filterUsers();
        });
    });
    
    // Удаление пользователя
    function deleteUser(id) {
        if (confirm('Вы уверены, что хотите удалить этого пользователя? Это действие нельзя отменить.')) {
            fetch(`/admin/users/${id}/delete`, { method: 'POST' })
                .then(() => location.reload());
        }
    }
    
    // Модальное окно
    function openAddModal() {
        document.getElementById('addUserModal').classList.add('active');
    }
    
    function closeModal() {
        document.getElementById('addUserModal').classList.remove('active');
    }
    
    // Закрытие модалки по клику вне
    document.getElementById('addUserModal').addEventListener('click', (e) => {
        if (e.target === document.getElementById('addUserModal')) {
            closeModal();
        }
    });
    
    // Анимация появления
    const reveals = document.querySelectorAll('.stat-mini-card, .users-table-container');
    reveals.forEach(el => {
        el.style.opacity = '0';
        el.style.transform = 'translateY(20px)';
        setTimeout(() => {
            el.style.transition = 'all 0.5s ease';
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
        }, 100);
    });
</script>

<%- include('../partials/admin/footer') %>