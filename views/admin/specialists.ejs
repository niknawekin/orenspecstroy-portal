<%- include('../partials/admin/header') %>
<%- include('../partials/admin/sidebar') %>

<style>
    .specialists-page {
        padding-top: 100px;
        padding-bottom: 60px;
        background: linear-gradient(135deg, #0a0a0a 0%, #0f0f0f 100%);
        min-height: 100vh;
    }
    
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
        flex-wrap: wrap;
        gap: 20px;
    }
    
    .page-header h1 {
        font-size: 2rem;
        background: linear-gradient(135deg, #fff, #e31b23);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }
    
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
    }
    
    .stat-card {
        background: rgba(26, 26, 26, 0.8);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        border: 1px solid rgba(255,255,255,0.05);
    }
    
    .stat-card .number {
        font-size: 2rem;
        font-weight: 800;
        color: #e31b23;
    }
    
    .specialists-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: 25px;
    }
    
    .specialist-card {
        background: rgba(26, 26, 26, 0.8);
        border-radius: 20px;
        overflow: hidden;
        border: 1px solid rgba(255,255,255,0.05);
        transition: all 0.3s ease;
    }
    
    .specialist-card:hover {
        transform: translateY(-5px);
        border-color: #e31b23;
    }
    
    .card-header {
        background: linear-gradient(135deg, #1a1a1a, #0f0f0f);
        padding: 20px;
        text-align: center;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    
    .avatar {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #e31b23, #b3050f);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 15px;
        font-size: 2rem;
        font-weight: 700;
    }
    
    .rating {
        color: #ffc107;
        margin-top: 10px;
    }
    
    .card-body {
        padding: 20px;
    }
    
    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    
    .info-label {
        color: #888;
    }
    
    .info-value {
        color: white;
        font-weight: 500;
    }
    
    .card-actions {
        padding: 20px;
        display: flex;
        gap: 10px;
        border-top: 1px solid rgba(255,255,255,0.05);
    }
    
    .btn-calendar {
        flex: 1;
        background: rgba(23, 162, 184, 0.2);
        color: #17a2b8;
        text-align: center;
        padding: 10px;
        border-radius: 10px;
        text-decoration: none;
        transition: 0.3s;
    }
    
    .btn-calendar:hover {
        background: #17a2b8;
        color: white;
    }
    
    .btn-delete {
        background: rgba(227, 27, 35, 0.2);
        color: #e31b23;
        border: none;
        padding: 10px 20px;
        border-radius: 10px;
        cursor: pointer;
        transition: 0.3s;
    }
    
    .btn-delete:hover {
        background: #e31b23;
        color: white;
    }
    
    .modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.8);
        z-index: 1000;
        align-items: center;
        justify-content: center;
    }
    
    .modal.active {
        display: flex;
    }
    
    .modal-content {
        background: #1a1a1a;
        border-radius: 20px;
        padding: 30px;
        max-width: 500px;
        width: 90%;
    }
    
    .form-group {
        margin-bottom: 20px;
    }
    
    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: #888;
    }
    
    .form-group input, .form-group select {
        width: 100%;
        padding: 12px;
        background: #2a2a2a;
        border: 1px solid #444;
        border-radius: 10px;
        color: white;
    }
    
    .btn-add {
        background: linear-gradient(135deg, #28a745, #1e7e34);
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 10px;
        cursor: pointer;
    }
    
    .btn-back {
        background: #333;
        color: white;
        padding: 10px 20px;
        border-radius: 10px;
        text-decoration: none;
    }
</style>

<main class="specialists-page">
    <div class="container">
        <div class="page-header">
            <h1><i class="fas fa-user-cog"></i> Специалисты</h1>
            <div>
                <a href="/admin" class="btn-back">← Назад</a>
                <button onclick="openAddModal()" class="btn-add" style="margin-left: 10px;">
                    <i class="fas fa-plus"></i> Добавить специалиста
                </button>
            </div>
        </div>
        
        <div class="stats-grid">
            <div class="stat-card">
                <div class="number"><%= specialists.length %></div>
                <div>Всего специалистов</div>
            </div>
            <div class="stat-card">
                <div class="number"><%= specialists.filter(s => s.rating >= 4.5).length %></div>
                <div>С высоким рейтингом</div>
            </div>
            <div class="stat-card">
                <div class="number"><%= specialists.reduce((sum, s) => sum + (s.upcoming_bookings || 0), 0) %></div>
                <div>Предстоящих выездов</div>
            </div>
        </div>
        
        <div class="specialists-grid">
            <% specialists.forEach(spec => { %>
                <div class="specialist-card">
                    <div class="card-header">
                        <div class="avatar">
                            <%= (spec.fio && spec.fio.trim()) ? spec.fio.trim().charAt(0).toUpperCase() : '?' %>
                        </div>
                        <h3><%= spec.fio || 'ФИО не указано' %></h3>
                        <div class="rating">
                            <% for(let i = 0; i < Math.floor(spec.rating); i++) { %>
                                <i class="fas fa-star"></i>
                            <% } %>
                            <% if(spec.rating % 1 >= 0.5) { %>
                                <i class="fas fa-star-half-alt"></i>
                            <% } %>
                            <span style="color: #888;"> <%= spec.rating %></span>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-wrench"></i> Специализация:</span>
                            <span class="info-value"><%= spec.specialization || 'Универсал' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-briefcase"></i> Опыт:</span>
                            <span class="info-value"><%= spec.experience || 0 %> лет</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-phone"></i> Телефон:</span>
                            <span class="info-value"><%= spec.user_phone || spec.phone || '-' %></span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-calendar"></i> Ближайшие выезды:</span>
                            <span class="info-value"><%= spec.upcoming_bookings || 0 %></span>
                        </div>
                    </div>
                    <div class="card-actions">
                        <a href="/admin/specialists/<%= spec.id %>/calendar" class="btn-calendar">
                            <i class="fas fa-calendar-alt"></i> Календарь
                        </a>
                        <button onclick="deleteSpecialist(<%= spec.id %>)" class="btn-delete">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
</main>

<!-- Модальное окно добавления -->
<div id="addModal" class="modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); align-items: center; justify-content: center; z-index: 1000;">
    <div class="modal-content" style="background: #111; border: 1px solid #333; padding: 30px; border-radius: 16px; width: 100%; max-width: 500px; color: white;">
        <h2 style="margin-bottom: 20px; color: #e31b23;">Регистрация нового специалиста</h2>
        
        <form action="/admin/specialists/add" method="POST">
            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">ФИО Мастера</label>
                <input type="text" name="fio" required style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Email (для входа)</label>
                <input type="email" name="email" required style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Телефон</label>
                <input type="text" name="phone" placeholder="+7 (999) 123-45-67" required style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Пароль учетной записи</label>
                <input type="password" name="password" required style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
            </div>

            <div class="form-group" style="margin-bottom: 15px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Специализация</label>
                <select name="specialization" style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
                    <option value="Универсал">Универсал</option>
                    <option value="Шлагбаумы">Шлагбаумы</option>
                    <option value="Ворота">Автоматические ворота</option>
                    <option value="Электрика">Электрика</option>
                </select>
            </div>

            <div class="form-group" style="margin-bottom: 20px;">
                <label style="display: block; margin-bottom: 5px; color: #888;">Опыт работы (лет)</label>
                <input type="number" name="experience" value="1" min="0" style="width: 100%; padding: 10px; background: #161616; border: 1px solid #333; color: white; border-radius: 8px;">
            </div>

            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <button type="button" onclick="closeModal()" style="background: #222; color: white; border: 1px solid #333; padding: 10px 20px; border-radius: 8px; cursor: pointer;">Отмена</button>
                <button type="submit" style="background: #e31b23; color: white; border: none; padding: 10px 20px; border-radius: 8px; cursor: pointer; font-weight: bold;">Создать и открыть доступ</button>
            </div>
        </form>
    </div>
</div>

<script>
    // Универсальные функции для управления модальным окном
    const modal = document.getElementById('addModal');

    function openAddModal() {
        modal.style.display = 'flex';
    }
    
    function closeModal() {
        modal.style.display = 'none';
    }
    
    // Закрытие по клику на фон
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            closeModal();
        }
    });

    // Функция удаления
    function deleteSpecialist(id) {
        if(confirm('Вы уверены, что хотите удалить специалиста?')) {
            fetch(`/admin/specialists/${id}/delete`, { method: 'POST' })
                .then(response => {
                    if (response.ok) location.reload();
                    else alert('Ошибка при удалении');
                })
                .catch(err => console.error(err));
        }
    }
</script>

<%- include('../partials/admin/footer') %>