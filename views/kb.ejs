<%- include('partials/header') %>

<style>
    /* Дополнительные стили для страницы базы знаний */
    .kb-hero {
        position: relative;
        height: 50vh;
        min-height: 400px;
        background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        overflow: hidden;
    }

    .kb-hero::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url('data:image/svg+xml;utf8,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1000 1000" opacity="0.1"><path fill="%23E30613" d="M0,0 L1000,0 L1000,1000 L0,1000 Z M500,200 L200,800 L800,800 Z"/></svg>');
        background-size: cover;
        background-position: center;
        animation: slowZoom 20s ease-in-out infinite;
    }

    @keyframes slowZoom {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); }
        100% { transform: scale(1); }
    }

    .kb-hero-content {
        position: relative;
        z-index: 2;
    }

    .kb-hero h1 {
        font-size: 3.5rem;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 5px;
        margin-bottom: 20px;
        background: linear-gradient(135deg, #fff 0%, #E30613 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .kb-hero p {
        font-size: 1.2rem;
        color: #ccc;
        max-width: 600px;
        margin: 0 auto;
    }

    .search-section {
        padding: 60px 0;
        background: linear-gradient(135deg, #111 0%, #0a0a0a 100%);
    }

    .search-container {
        max-width: 700px;
        margin: 0 auto;
        position: relative;
    }

    .search-container input {
        width: 100%;
        padding: 18px 25px;
        font-size: 1rem;
        background: #1a1a1a;
        border: 2px solid #333;
        border-radius: 50px;
        color: white;
        outline: none;
        transition: all 0.3s ease;
        font-family: 'Montserrat', sans-serif;
    }

    .search-container input:focus {
        border-color: var(--primary-red);
        box-shadow: 0 0 20px rgba(227, 6, 19, 0.3);
    }

    .search-container i {
        position: absolute;
        right: 20px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--primary-red);
        font-size: 1.2rem;
    }

    /* Категории */
    .categories-section {
        padding: 60px 0;
        background: #0f0f0f;
    }

    .section-title {
        text-align: center;
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 50px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .section-title span {
        color: var(--primary-red);
    }

    .categories-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .category-card {
        background: #1a1a1a;
        padding: 40px 30px;
        border-radius: 15px;
        text-align: center;
        cursor: pointer;
        transition: all 0.3s ease;
        border: 1px solid #2a2a2a;
        position: relative;
        overflow: hidden;
    }

    .category-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 100%;
        height: 3px;
        background: var(--primary-red);
        transition: left 0.3s ease;
    }

    .category-card:hover::before {
        left: 0;
    }

    .category-card:hover {
        transform: translateY(-10px);
        border-color: var(--primary-red);
        box-shadow: 0 10px 30px rgba(227, 6, 19, 0.2);
    }

    .category-card i {
        font-size: 3rem;
        color: var(--primary-red);
        margin-bottom: 20px;
    }

    .category-card h3 {
        font-size: 1.3rem;
        margin-bottom: 10px;
    }

    .category-card p {
        color: #888;
        font-size: 0.9rem;
    }

    .category-badge {
        display: inline-block;
        margin-top: 15px;
        padding: 5px 12px;
        background: rgba(227, 6, 19, 0.1);
        border-radius: 20px;
        font-size: 0.75rem;
        color: var(--primary-red);
    }

    /* Контентная секция */
    .content-section {
        padding: 60px 0;
        background: #0a0a0a;
    }

    .content-grid {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .kb-articles {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
        gap: 30px;
        margin-bottom: 50px;
    }

    .article-card {
        background: #111;
        border-radius: 15px;
        overflow: hidden;
        border: 1px solid #222;
        transition: all 0.3s ease;
    }

    .article-card:hover {
        transform: translateY(-5px);
        border-color: var(--primary-red);
    }

    .article-header {
        padding: 20px;
        background: linear-gradient(135deg, #1a1a1a 0%, #0a0a0a 100%);
        border-bottom: 1px solid #222;
    }

    .article-header i {
        color: var(--primary-red);
        font-size: 1.5rem;
        margin-bottom: 15px;
    }

    .article-header h3 {
        font-size: 1.2rem;
        margin-bottom: 10px;
    }

    .article-meta {
        display: flex;
        gap: 15px;
        font-size: 0.75rem;
        color: #666;
    }

    .article-body {
        padding: 20px;
    }

    .article-body p {
        color: #aaa;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .article-footer {
        padding: 15px 20px;
        border-top: 1px solid #222;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .btn-read {
        color: var(--primary-red);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        transition: 0.3s;
    }

    .btn-read:hover {
        letter-spacing: 1px;
    }

    .rating {
        display: flex;
        gap: 5px;
        color: #ffc107;
        font-size: 0.8rem;
    }

    /* Видео-секция */
    .video-section {
        padding: 60px 0;
        background: linear-gradient(135deg, #111 0%, #0a0a0a 100%);
    }

    .video-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 30px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .video-card {
        background: #1a1a1a;
        border-radius: 15px;
        overflow: hidden;
        cursor: pointer;
        transition: 0.3s;
    }

    .video-card:hover {
        transform: scale(1.02);
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
    }

    .video-thumbnail {
        position: relative;
        height: 200px;
        background-size: cover;
        background-position: center;
    }

    .play-btn {
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        width: 60px;
        height: 60px;
        background: var(--primary-red);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.3s;
    }

    .play-btn i {
        color: white;
        font-size: 1.5rem;
        margin-left: 5px;
    }

    .video-card:hover .play-btn {
        transform: translate(-50%, -50%) scale(1.1);
    }

    .video-info {
        padding: 20px;
    }

    .video-info h4 {
        margin-bottom: 10px;
    }

    .video-duration {
        color: var(--primary-red);
        font-size: 0.75rem;
        font-weight: 600;
    }

    /* Модальное окно для видео */
    .video-modal {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(0,0,0,0.95);
        z-index: 10000;
        align-items: center;
        justify-content: center;
    }

    .video-modal.active {
        display: flex;
    }

    .video-modal-content {
        position: relative;
        max-width: 800px;
        width: 90%;
    }

    .video-modal-content iframe {
        width: 100%;
        height: 450px;
        border: none;
    }

    .close-modal {
        position: absolute;
        top: -40px;
        right: 0;
        color: white;
        font-size: 2rem;
        cursor: pointer;
    }

    /* PDF секция */
    .pdf-section {
        padding: 60px 0;
        background: #0f0f0f;
    }

    .pdf-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 25px;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .pdf-card {
        background: #111;
        border-radius: 10px;
        padding: 25px;
        display: flex;
        align-items: center;
        gap: 20px;
        border: 1px solid #222;
        transition: 0.3s;
        text-decoration: none;
        color: white;
    }

    .pdf-card:hover {
        border-color: var(--primary-red);
        transform: translateX(5px);
    }

    .pdf-card i {
        font-size: 2.5rem;
        color: var(--primary-red);
    }

    .pdf-info h4 {
        font-size: 1rem;
        margin-bottom: 5px;
    }

    .pdf-info p {
        font-size: 0.75rem;
        color: #666;
    }

    /* Часто задаваемые вопросы */
    .faq-section {
        padding: 60px 0;
        background: linear-gradient(135deg, #0a0a0a 0%, #111 100%);
    }

    .faq-grid {
        max-width: 900px;
        margin: 0 auto;
        padding: 0 20px;
    }

    .faq-item {
        background: #1a1a1a;
        margin-bottom: 15px;
        border-radius: 10px;
        overflow: hidden;
    }

    .faq-question {
        padding: 20px;
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        transition: 0.3s;
    }

    .faq-question:hover {
        background: #222;
    }

    .faq-question h4 {
        font-size: 1rem;
        margin: 0;
    }

    .faq-question i {
        color: var(--primary-red);
        transition: 0.3s;
    }

    .faq-answer {
        padding: 0 20px;
        max-height: 0;
        overflow: hidden;
        transition: 0.3s ease;
        color: #aaa;
        line-height: 1.6;
    }

    .faq-item.active .faq-answer {
        padding: 0 20px 20px 20px;
        max-height: 200px;
    }

    .faq-item.active .faq-question i {
        transform: rotate(180deg);
    }

    /* Адаптив */
    @media (max-width: 768px) {
        .kb-hero h1 {
            font-size: 2rem;
        }
        
        .kb-hero p {
            font-size: 0.9rem;
            padding: 0 20px;
        }
        
        .kb-articles {
            grid-template-columns: 1fr;
        }
        
        .video-modal-content iframe {
            height: 250px;
        }
    }
</style>

<main>
    <!-- Hero секция с параллакс эффектом -->
    <div class="kb-hero">
        <div class="parallax-bg" style="background-image: url('https://images.unsplash.com/photo-1582139329536-e7284fece509?q=80&w=2000'); filter: brightness(0.3);"></div>
        <div class="kb-hero-content reveal">
            <h1>База знаний</h1>
            <p>Инструкции, руководства и полезные материалы для эффективной работы с оборудованием</p>
        </div>
    </div>

    <!-- Поиск -->
    <div class="search-section">
        <div class="container">
            <div class="search-container reveal">
                <input type="text" id="searchInput" placeholder="Поиск по базе знаний...">
                <i class="fas fa-search"></i>
            </div>
        </div>
    </div>

    <!-- Категории -->
    <div class="categories-section">
        <div class="container">
            <h2 class="section-title reveal">Категории <span>знаний</span></h2>
            <div class="categories-grid">
                <div class="category-card reveal" data-category="instructions">
                    <i class="fas fa-book-open"></i>
                    <h3>Инструкции</h3>
                    <p>Руководства по эксплуатации и настройке</p>
                    <span class="category-badge">12 статей</span>
                </div>
                <div class="category-card reveal" data-category="video">
                    <i class="fas fa-video"></i>
                    <h3>Видеоуроки</h3>
                    <p>Наглядные видеоинструкции</p>
                    <span class="category-badge">8 видео</span>
                </div>
                <div class="category-card reveal" data-category="faq">
                    <i class="fas fa-question-circle"></i>
                    <h3>FAQ</h3>
                    <p>Часто задаваемые вопросы</p>
                    <span class="category-badge">15 ответов</span>
                </div>
                <div class="category-card reveal" data-category="docs">
                    <i class="fas fa-file-alt"></i>
                    <h3>Документация</h3>
                    <p>Техническая документация и схемы</p>
                    <span class="category-badge">24 файла</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Статьи -->
    <div class="content-section" id="articlesSection">
        <div class="content-grid">
            <h2 class="section-title reveal">Популярные <span>статьи</span></h2>
            <div class="kb-articles" id="articlesContainer">
                <!-- Статья 1 -->
                <div class="article-card reveal" data-title="Как настроить привод Alutech">
                    <div class="article-header">
                        <i class="fas fa-microchip"></i>
                        <h3>Как настроить привод Alutech Levigato</h3>
                        <div class="article-meta">
                            <span><i class="far fa-calendar"></i> 15.03.2025</span>
                            <span><i class="far fa-eye"></i> 234 просмотра</span>
                        </div>
                    </div>
                    <div class="article-body">
                        <p>Пошаговая инструкция по настройке автоматических приводов для роллет и ворот. Настройка концевых выключателей, программирование пульта и диагностика ошибок.</p>
                    </div>
                    <div class="article-footer">
                        <a href="#" class="btn-read">Читать полностью →</a>
                        <div class="rating">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star-half-alt"></i>
                        </div>
                    </div>
                </div>

                <!-- Статья 2 -->
                <div class="article-card reveal" data-title="Устранение неисправностей шлагбаума">
                    <div class="article-header">
                        <i class="fas fa-tools"></i>
                        <h3>Устранение неисправностей шлагбаума</h3>
                        <div class="article-meta">
                            <span><i class="far fa-calendar"></i> 10.03.2025</span>
                            <span><i class="far fa-eye"></i> 189 просмотров</span>
                        </div>
                    </div>
                    <div class="article-body">
                        <p>Частые поломки автоматических шлагбаумов и способы их быстрого устранения. Диагностика электропривода, замена пружины и настройка фотоэлементов.</p>
                    </div>
                    <div class="article-footer">
                        <a href="#" class="btn-read">Читать полностью →</a>
                        <div class="rating">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="far fa-star"></i>
                        </div>
                    </div>
                </div>

                <!-- Статья 3 -->
                <div class="article-card reveal" data-title="Программирование пультов ДУ">
                    <div class="article-header">
                        <i class="fas fa-wifi"></i>
                        <h3>Программирование пультов дистанционного управления</h3>
                        <div class="article-meta">
                            <span><i class="far fa-calendar"></i> 05.03.2025</span>
                            <span><i class="far fa-eye"></i> 312 просмотров</span>
                        </div>
                    </div>
                    <div class="article-body">
                        <p>Инструкция по программированию и синхронизации пультов ДУ с приемниками различных моделей. Сброс памяти и добавление новых брелоков.</p>
                    </div>
                    <div class="article-footer">
                        <a href="#" class="btn-read">Читать полностью →</a>
                        <div class="rating">
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                            <i class="fas fa-star"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Видеоуроки -->
    <div class="video-section">
        <div class="container">
            <h2 class="section-title reveal">Видео<span>уроки</span></h2>
            <div class="video-grid">
                <div class="video-card reveal">
                    <div class="video-thumbnail" style="background-image: url('https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg');">
                        <div class="play-btn" data-video="dQw4w9WgXcQ">
                            <i class="fas fa-play"></i>
                        </div>
                    </div>
                    <div class="video-info">
                        <h4>Настройка автоматических ворот</h4>
                        <p>Полное руководство по монтажу и настройке</p>
                        <span class="video-duration">15:24</span>
                    </div>
                </div>
                <div class="video-card reveal">
                    <div class="video-thumbnail" style="background-image: url('https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg');">
                        <div class="play-btn" data-video="dQw4w9WgXcQ">
                            <i class="fas fa-play"></i>
                        </div>
                    </div>
                    <div class="video-info">
                        <h4>Диагностика неисправностей</h4>
                        <p>Как найти и устранить поломку самостоятельно</p>
                        <span class="video-duration">22:10</span>
                    </div>
                </div>
                <div class="video-card reveal">
                    <div class="video-thumbnail" style="background-image: url('https://img.youtube.com/vi/dQw4w9WgXcQ/maxresdefault.jpg');">
                        <div class="play-btn" data-video="dQw4w9WgXcQ">
                            <i class="fas fa-play"></i>
                        </div>
                    </div>
                    <div class="video-info">
                        <h4>Обслуживание шлагбаумов</h4>
                        <p>Регулярное ТО и продление срока службы</p>
                        <span class="video-duration">18:45</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- PDF документация -->
    <div class="pdf-section">
        <div class="container">
            <h2 class="section-title reveal">Техническая <span>документация</span></h2>
            <div class="pdf-grid">
                <a href="#" class="pdf-card reveal">
                    <i class="fas fa-file-pdf"></i>
                    <div class="pdf-info">
                        <h4>Руководство Alutech Levigato</h4>
                        <p>PDF • 2.4 MB</p>
                    </div>
                </a>
                <a href="#" class="pdf-card reveal">
                    <i class="fas fa-file-pdf"></i>
                    <div class="pdf-info">
                        <h4>Схемы подключения Nice</h4>
                        <p>PDF • 1.8 MB</p>
                    </div>
                </a>
                <a href="#" class="pdf-card reveal">
                    <i class="fas fa-file-pdf"></i>
                    <div class="pdf-info">
                        <h4>Каталог запчастей 2025</h4>
                        <p>PDF • 5.2 MB</p>
                    </div>
                </a>
                <a href="#" class="pdf-card reveal">
                    <i class="fas fa-file-word"></i>
                    <div class="pdf-info">
                        <h4>Акт выполненных работ</h4>
                        <p>DOCX • 0.5 MB</p>
                    </div>
                </a>
            </div>
        </div>
    </div>

    <!-- FAQ -->
    <div class="faq-section">
        <div class="container">
            <h2 class="section-title reveal">Часто задаваемые <span>вопросы</span></h2>
            <div class="faq-grid">
                <div class="faq-item reveal">
                    <div class="faq-question">
                        <h4>Как долго длится гарантийное обслуживание?</h4>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Гарантийный срок составляет 24 месяца с момента подписания акта приема-передачи оборудования. В течение этого периода все ремонтные работы и замена деталей производятся бесплатно.</p>
                    </div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-question">
                        <h4>Можно ли вызвать специалиста в выходной день?</h4>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Да, выезд специалиста возможен в субботу с 9:00 до 18:00. Воскресенье — выходной день. Заявки, поданные в пятницу после 16:00, обрабатываются в понедельник.</p>
                    </div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-question">
                        <h4>Какие документы нужны для гарантийного ремонта?</h4>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Необходимы: гарантийный талон, кассовый чек или договор, акт приема-передачи оборудования. При отсутствии документов гарантийный ремонт не производится.</p>
                    </div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-question">
                        <h4>Как быстро приедет мастер после заявки?</h4>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Среднее время прибытия специалиста — от 2 до 24 часов в зависимости от загруженности. Для экстренных заявок (аварийная ситуация) выезд в течение 2 часов.</p>
                    </div>
                </div>
                <div class="faq-item reveal">
                    <div class="faq-question">
                        <h4>Есть ли скидки для постоянных клиентов?</h4>
                        <i class="fas fa-chevron-down"></i>
                    </div>
                    <div class="faq-answer">
                        <p>Да, для клиентов, оформивших более 3 заявок, действует скидка 5% на работы. При 5+ заявках — 10%. Скидка не суммируется с акционными предложениями.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<!-- Модальное окно для видео -->
<div class="video-modal" id="videoModal">
    <div class="video-modal-content">
        <span class="close-modal">&times;</span>
        <iframe id="videoFrame" src="" allowfullscreen></iframe>
    </div>
</div>

<script>
    // Анимация появления
    const reveals = document.querySelectorAll('.reveal');
    
    function revealElements() {
        reveals.forEach(element => {
            const windowHeight = window.innerHeight;
            const elementTop = element.getBoundingClientRect().top;
            const elementVisible = 150;
            
            if (elementTop < windowHeight - elementVisible) {
                element.classList.add('active');
            }
        });
    }
    
    window.addEventListener('scroll', revealElements);
    revealElements();
    
    // Поиск статей
    const searchInput = document.getElementById('searchInput');
    const articles = document.querySelectorAll('.article-card');
    
    searchInput.addEventListener('input', function() {
        const searchTerm = this.value.toLowerCase();
        
        articles.forEach(article => {
            const title = article.getAttribute('data-title') || article.querySelector('.article-header h3').innerText.toLowerCase();
            
            if (title.includes(searchTerm) || searchTerm === '') {
                article.style.display = 'block';
                article.classList.add('reveal');
            } else {
                article.style.display = 'none';
            }
        });
    });
    
    // Фильтр по категориям
    const categoryCards = document.querySelectorAll('.category-card');
    
    categoryCards.forEach(card => {
        card.addEventListener('click', function() {
            const category = this.getAttribute('data-category');
            
            // Прокрутка к соответствующей секции
            if (category === 'instructions') {
                document.getElementById('articlesSection').scrollIntoView({ behavior: 'smooth' });
            } else if (category === 'video') {
                document.querySelector('.video-section').scrollIntoView({ behavior: 'smooth' });
            } else if (category === 'faq') {
                document.querySelector('.faq-section').scrollIntoView({ behavior: 'smooth' });
            } else if (category === 'docs') {
                document.querySelector('.pdf-section').scrollIntoView({ behavior: 'smooth' });
            }
        });
    });
    
    // Аккордеон FAQ
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
        const question = item.querySelector('.faq-question');
        
        question.addEventListener('click', () => {
            item.classList.toggle('active');
        });
    });
    
    // Видео модальное окно
    const modal = document.getElementById('videoModal');
    const videoFrame = document.getElementById('videoFrame');
    const closeModal = document.querySelector('.close-modal');
    const playBtns = document.querySelectorAll('.play-btn');
    
    playBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const videoId = this.getAttribute('data-video');
            videoFrame.src = `https://www.youtube.com/embed/${videoId}?autoplay=1`;
            modal.classList.add('active');
        });
    });
    
    closeModal.addEventListener('click', () => {
        modal.classList.remove('active');
        videoFrame.src = '';
    });
    
    modal.addEventListener('click', (e) => {
        if (e.target === modal) {
            modal.classList.remove('active');
            videoFrame.src = '';
        }
    });
    
    // Добавляем класс active для анимации
    document.querySelectorAll('.reveal').forEach(el => {
        el.classList.add('reveal-left');
    });
</script>

<style>
    .reveal {
        opacity: 0;
        transition: all 0.8s cubic-bezier(0.17, 0.67, 0.83, 0.67);
    }
    .reveal-left {
        transform: translateX(-50px);
    }
    .reveal.active {
        opacity: 1;
        transform: translateX(0);
    }
    .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }
</style>

