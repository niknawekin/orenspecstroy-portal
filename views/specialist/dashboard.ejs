<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Панель Инженера | СПТС-ОСС</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { background: #070707; color: #fff; font-family: 'Segoe UI', Roboto, sans-serif; }
        .spec-header { background: #111; padding: 20px 40px; border-bottom: 1px solid #222; display: flex; justify-content: space-between; align-items: center; position: fixed; width: 100%; top:0; z-index: 100; box-sizing: border-box;}
        .container { max-width: 1200px; margin: 120px auto 60px; padding: 0 20px; }
        .spec-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 20px; margin-bottom: 40px; }
        .stat-card { background: #121212; border: 1px solid #222; border-radius: 12px; padding: 20px; text-align: center; border-left: 4px solid #888; }
        .stat-card.active { border-left-color: #ff9900; }
        .stat-card.emergency { border-left-color: #e31b23; box-shadow: 0 0 15px rgba(227, 27, 35, 0.1); }
        .stat-card.done { border-left-color: #00cc66; }
        .stat-card h3 { font-size: 2.2rem; margin: 5px 0; color: #fff; }
        
        .task-table { width: 100%; border-collapse: collapse; background: #111; border-radius: 12px; overflow: hidden; border: 1px solid #222; }
        .task-table th { background: #161616; color: #888; text-align: left; padding: 15px; font-size: 0.85rem; text-transform: uppercase; }
        .task-table td { padding: 15px; border-top: 1px solid #222; font-size: 0.95rem; }
        .task-row:hover { background: #151515; }
        
        .badge { padding: 4px 10px; border-radius: 6px; font-size: 0.8rem; font-weight: bold; }
        .badge.emergency { background: rgba(227, 27, 35, 0.1); color: #ff3333; border: 1px solid #ff3333; }
        .badge.urgent { background: rgba(255, 153, 0, 0.1); color: #ff9900; }
        .badge.normal { background: #222; color: #aaa; }
        
        .btn-action { background: #e31b23; color: white; border: none; padding: 6px 14px; border-radius: 6px; text-decoration: none; font-size: 0.85rem; font-weight: bold; transition: 0.3s; }
        .btn-action:hover { background: #ff1e27; transform: translateY(-1px); }
        .logout-link { color: #aaa; text-decoration: none; font-size: 0.9rem; transition: 0.3s; }
        .logout-link:hover { color: #e31b23; }
    </style>
</head>
<body>

    <header class="spec-header">
        <div style="display: flex; align-items: center; gap: 15px;">
            <span style="font-weight: 900; letter-spacing: 1px; font-size: 1.1rem;"><span style="color:#e31b23;">ОПС</span> ТЕРМИНАЛ ТЕХНИКА</span>
            <span style="color: #444;">|</span>
            <span style="color: #aaa; font-size: 0.9rem;"><i class="fas fa-user-gear"></i> <%= user.fio %></span>
        </div>
        <a href="/logout" class="logout-link"><i class="fas fa-sign-out-alt"></i> Выйти</a>
    </header>

    <div class="container">
        <div class="spec-stats">
            <div class="stat-card active">
                <p style="color: #888; margin:0;">В работе у меня</p>
                <h3><%= stats.active %></h3>
            </div>
            <div class="stat-card emergency">
                <p style="color: #ff3333; margin:0;">🚨 Аварийные наряды</p>
                <h3><%= stats.emergency %></h3>
            </div>
            <div class="stat-card done">
                <p style="color: #888; margin:0;">Выполнено задач</p>
                <h3><%= stats.completed %></h3>
            </div>
        </div>

        <h2 style="font-size: 1.4rem; margin-bottom: 20px; font-weight: 700;"><i class="fas fa-route" style="color:#e31b23;"></i> Мой график выездов</h2>
        <div class="filter-container" style="margin-bottom: 20px; display: flex; gap: 10px;">
            <button class="filter-btn active" data-filter="all" style="background: #222; color: #fff; border: 1px solid #333; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Все задачи</button>
            <button class="filter-btn" data-filter="active" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">В работе</button>
            <button class="filter-btn" data-filter="emergency" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">🚨 Аварийные</button>
            <button class="filter-btn" data-filter="completed" style="background: #111; color: #aaa; border: 1px solid #222; padding: 8px 16px; border-radius: 6px; cursor: pointer; font-weight: bold;">Выполненные</button>
        </div>
        <table class="task-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата / Время</th>
                    <th>Тема неисправности</th>
                    <th>Адрес объекта</th>
                    <th>Срочность</th>
                    <th>Статус</th>
                    <th>Действие</th>
                </tr>
            </thead>
            <tbody>
                <% tasks.forEach(task => { %>
                    <tr class="task-row" data-status="<%= task.status %>" data-urgency="<%= task.urgency %>">
                        <td style="color: #e31b23; font-weight: bold;">#<%= task.id %></td>
                        <td>
                            <i class="fas fa-calendar-day" style="color:#666; margin-right:5px;"></i>
                            <strong><%= new Date(task.scheduled_date).toLocaleDateString('ru-RU') %></strong> 
                            <span style="color:#666; margin-left:5px;"><%= task.time_slot %></span>
                        </td>
                        <td><strong><%= task.subject %></strong></td>
                        <td style="color: #ccc;"><%= task.address || 'Не указан' %></td>
                        <td>
                            <span class="badge <%= task.urgency %>">
                                <%= task.urgency === 'emergency' ? 'Аварийная' : (task.urgency === 'urgent' ? 'Срочная' : 'Обычная') %>
                            </span>
                        </td>
                        <td>
                            <span style="color: <%= task.status === 'Выполнено' ? '#00cc66' : '#ff9900' %>; font-weight: bold;">
                                <%= task.status %>
                            </span>
                        </td>
                        <td>
                            <a href="/specialist/tickets/<%= task.id %>" class="btn-action">Открыть</a>
                        </td>
                    </tr>
                <% }) %>
                <% if (tasks.length === 0) { %>
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 40px; color: #555;">У вас пока нет назначенных выездов.</td>
                    </tr>
                <% } %>
            </tbody>
        </table>
    </div>
    <script>
        document.querySelectorAll('.filter-btn').forEach(button => {
            button.addEventListener('click', function() {
                // Убираем активный класс у всех кнопок и добавляем текущей
                document.querySelectorAll('.filter-btn').forEach(b => {
                    b.classList.remove('active');
                    b.style.background = '#111';
                    b.style.color = '#aaa';
                    b.style.borderColor = '#222';
                });
                this.classList.add('active');
                this.style.background = '#222';
                this.style.color = '#fff';
                this.style.borderColor = '#333';

                const filter = this.getAttribute('data-filter');
                
                document.querySelectorAll('.task-row').forEach(row => {
                    const status = row.getAttribute('data-status');
                    const urgency = row.getAttribute('data-urgency');

                    if (filter === 'all') {
                        row.style.display = '';
                    } else if (filter === 'active') {
                        if (status !== 'Выполнено' && status !== 'Закрыта') {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    } else if (filter === 'emergency') {
                        if (urgency === 'emergency' && status !== 'Выполнено') {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    } else if (filter === 'completed') {
                        if (status === 'Выполнено') {
                            row.style.display = '';
                        } else {
                            row.style.display = 'none';
                        }
                    }
                });
            });
        });
    </script>
</body>
</html>